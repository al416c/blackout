:root {
    /* DEFAULT (WHITE MODE) */
    --bg:        #ffffff;
    --bg-card:   #f5f5f5;
    --bg-panel:  #e0e0e0;
    --border:    #cccccc;
    --text:      #000000;
    --text-dim:  #555555;
    
    --accent:    #e62248;
    --accent2:   #ff6644;
    --green:     #00aa66;
    --blue:      #2266ee;
    --orange:    #ee7711;
    --purple:    #8822ee;
    --yellow:    #ddaa00;
    --red:       #ee1133;
    
    --font:      'Segoe UI', system-ui, -apple-system, sans-serif;
    --mono:      'SF Mono', 'Fira Code', 'Consolas', monospace;
}

body.dark-theme {
    /* DARK MODE */
    --bg:        #0a0a0f;
    --bg-card:   #12121a;
    --bg-panel:  #16161f;
    --border:    #2a2a3a;
    --text:      #e0e0e8;
    --text-dim:  #7a7a8e;
    
    --accent:    #ff3355;
    --accent2:   #ff6644;
    --green:     #00cc88;
    --blue:      #3388ff;
    --orange:    #ff9933;
    --purple:    #aa44ff;
    --yellow:    #ffcc00;
    --red:       #ff2244;
}
